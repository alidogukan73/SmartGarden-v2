<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/healthRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="40dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/back_to_main"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="←"
                android:textColor="@color/textPrimary"
                android:textSize="24sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="22dp"
                app:rippleColor="@color/accentLight"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/title_device_health"
                    android:textAppearance="@style/TextAppearance.SmartGarden.ScreenTitle"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/subtitle_device_health"
                    android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHealthSummary"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="@color/onlineBackground"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/online"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/txtHealthSummaryIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="●"
                    android:textColor="@color/online"
                    android:textSize="22sp"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <!-- GENEL DURUM -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOverallHealth"
            style="@style/Widget.SmartGarden.Card.Featured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_overall_label"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    <TextView
                        android:id="@+id/txtOverallHealth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/health_status_waiting"
                        android:textColor="@color/textPrimary"
                        android:textSize="21sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtLastHealthUpdate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/health_update_waiting"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOverallHealthBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="@color/surfaceSoft"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/txtOverallHealthBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="@string/health_badge_checking"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- CPU -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/health_cpu_title"
                    android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/health_cpu_subtitle"
                    android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/txtCpuTemperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/health_default_temperature"
                            android:textColor="@color/textPrimary"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/health_cpu_temperature"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/divider"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/txtCpuUsage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/health_default_percentage"
                            android:textColor="@color/textPrimary"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/health_cpu_usage"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressCpu"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="14dp"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="@color/divider"
                    android:progressTint="@color/primary"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- RAM VE DISK -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartGarden.Card.Main"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_ram_title"
                        android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                    <TextView
                        android:id="@+id/txtRamUsage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:text="@string/health_default_percentage"
                        android:textColor="@color/primary"
                        android:textSize="30sp"
                        android:textStyle="bold"/>

                    <ProgressBar
                        android:id="@+id/progressRam"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:layout_marginTop="14dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/divider"
                        android:progressTint="@color/primary"/>

                    <TextView
                        android:id="@+id/txtRamDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/health_detail_waiting"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartGarden.Card.Main"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_disk_title"
                        android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                    <TextView
                        android:id="@+id/txtDiskUsage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:text="@string/health_default_percentage"
                        android:textColor="@color/primary"
                        android:textSize="30sp"
                        android:textStyle="bold"/>

                    <ProgressBar
                        android:id="@+id/progressDisk"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:layout_marginTop="14dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/divider"
                        android:progressTint="@color/primary"/>

                    <TextView
                        android:id="@+id/txtDiskDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/health_detail_waiting"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <!-- AĞ BİLGİLERİ -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/health_network_title"
                    android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/health_network_subtitle"
                    android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/health_wifi_signal"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                        <TextView
                            android:id="@+id/txtWifiSignal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/health_default_signal"
                            android:textColor="@color/textPrimary"
                            android:textSize="19sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/txtWifiQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/health_status_waiting"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardWifiStatus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardBackgroundColor="@color/surfaceSoft"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/txtWifiStatusIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="●"
                            android:textColor="@color/textSecondary"
                            android:textSize="22sp"/>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/health_ip_address"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    <TextView
                        android:id="@+id/txtIpAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="@string/health_default_ip"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- THROTTLING -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardThrottling"
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_throttling_title"
                        android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                    <TextView
                        android:id="@+id/txtThrottlingDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/health_throttling_waiting"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardThrottlingBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="@color/surfaceSoft"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/txtThrottlingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="@string/health_badge_checking"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- SİSTEM BİLGİLERİ -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/health_system_title"
                    android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/health_firmware"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    <TextView
                        android:id="@+id/txtFirmware"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_default_firmware"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/health_uptime"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    <TextView
                        android:id="@+id/txtUptime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health_detail_waiting"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>