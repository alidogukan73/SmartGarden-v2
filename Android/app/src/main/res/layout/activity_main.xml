<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:fadingEdgeLength="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="48dp">

        <!-- ===================================================== -->
        <!-- PROFESYONEL DASHBOARD HEADER                          -->
        <!-- ===================================================== -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Featured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- ÜST SATIR: MARKA + ANA MENÜ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- MARKA İKONU -->

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        app:cardBackgroundColor="@color/primaryLight"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- UYGULAMA BAŞLIĞI -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:text="@string/app_name"
                            android:textAppearance="@style/TextAppearance.SmartGarden.ScreenTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/app_subtitle"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                    </LinearLayout>

                    <!-- ANA MENÜ -->

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMainMenu"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="@string/open_main_menu"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        app:backgroundTint="@color/surfaceSoft"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_more_vert_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/textPrimary"
                        app:rippleColor="@color/divider"/>

                </LinearLayout>

                <!-- AYIRICI -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/divider" />

                <!-- CİHAZ BİLGİLERİ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_connected_device"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                        <TextView
                            android:id="@+id/txtDevice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/default_device_name"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- ONLINE / OFFLINE ROZETİ -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOnlineStatus"
                        style="@style/Widget.SmartGarden.Card.Success"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp">

                        <TextView
                            android:id="@+id/txtOnline"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/status_online"
                            android:textColor="@color/online"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- TOPRAK NEMİ KARTI -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="@string/title_soil_moisture"
                            android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/subtitle_live_sensor"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_live"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtMoisture"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:includeFontPadding="false"
                    android:text="0%"
                    android:textAppearance="@style/TextAppearance.SmartGarden.MoistureValue"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/txtMoistureStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:text="@string/moisture_waiting"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressMoisture"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="@color/divider"
                    android:progressTint="@color/primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.SmartGarden.Card.Inner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="13dp"
                            android:paddingBottom="13dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_voltage"
                                android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                            <TextView
                                android:id="@+id/txtVoltage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0.00 V"
                                android:textAppearance="@style/TextAppearance.SmartGarden.Value"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.SmartGarden.Card.Inner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="13dp"
                            android:paddingBottom="13dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_raw_value"
                                android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                            <TextView
                                android:id="@+id/txtRaw"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                android:textAppearance="@style/TextAppearance.SmartGarden.Value"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- SULAMA KONTROL KARTI -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/title_watering_control"
                    android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/subtitle_pump_and_mode"
                    android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPumpStatus"
                    style="@style/Widget.SmartGarden.Card.Inner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/offlineBackground"
                            app:cardCornerRadius="13dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/imgPumpStatus"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_pump_24"
                                app:tint="@color/offline" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_pump_status"
                                android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                            <TextView
                                android:id="@+id/txtRelay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/pump_stopped"
                                android:textColor="@color/offline"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtPumpDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="@string/pump_description_idle"
                                android:textColor="@color/textSecondary"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_pump"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Label" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAutoMode"
                    style="@style/Widget.SmartGarden.Card.Inner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="68dp"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/surfaceGreen"
                            app:cardCornerRadius="13dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/imgAutoMode"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_auto_mode_24"
                                app:tint="@color/primary" />

                        </com.google.android.material.card.MaterialCardView>


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/title_auto_watering"
                                android:textColor="@color/textPrimary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtAutoDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="@string/auto_mode_default_description"
                                android:textAppearance="@style/TextAppearance.SmartGarden.Body" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchAuto"
                            style="@style/Widget.SmartGarden.Switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/auto_mode_content_description" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWater"
                    style="@style/Widget.SmartGarden.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="14dp"
                    android:text="@string/button_start_manual_watering"
                    app:icon="@drawable/ic_water_drop_24"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/textOnPrimary" />

                <TextView
                    android:id="@+id/txtManualHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="@string/manual_hint_idle"
                    android:textColor="@color/textTertiary"
                    android:textSize="10sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>