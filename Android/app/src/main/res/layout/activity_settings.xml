<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="40dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/back_to_main"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="←"
                android:textColor="@color/textPrimary"
                android:textSize="24sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="22dp"
                app:rippleColor="@color/accentLight"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/title_settings"
                    android:textAppearance="@style/TextAppearance.SmartGarden.ScreenTitle"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/subtitle_settings"
                    android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

            </LinearLayout>

        </LinearLayout>


        <!-- KAYDEDİLMEMİŞ DEĞİŞİKLİKLER UYARISI -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUnsavedChanges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/warningBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/warning"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_unsaved_changes"
                    android:textColor="@color/warning"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/warning"
                    android:textSize="18sp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- SULAMA AYARLARI -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_irrigation_title"
                    android:textAppearance="@style/TextAppearance.SmartGarden.CardTitle"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/settings_irrigation_subtitle"
                    android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>


                <!-- NEM LİMİTİ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_moisture_limit"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_moisture_limit_description"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/primaryLight"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/txtMoistureLimitValue"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/settings_default_percentage"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderMoistureLimit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="10"
                    android:valueTo="80"
                    android:stepSize="1"
                    android:value="40"
                    app:haloColor="@color/accentLight"
                    app:thumbColor="@color/primary"
                    app:trackColorActive="@color/primary"
                    app:trackColorInactive="@color/divider"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider"/>


                <!-- POMPA SÜRESİ -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_pump_duration"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_pump_duration_description"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/infoBackground"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/info"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/txtPumpDurationValue"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/settings_default_seconds"
                            android:textColor="@color/info"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderPumpDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="5"
                    android:valueTo="60"
                    android:stepSize="1"
                    android:value="10"
                    app:haloColor="@color/infoBackground"
                    app:thumbColor="@color/info"
                    app:trackColorActive="@color/info"
                    app:trackColorInactive="@color/divider"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider"/>


                <!-- COOLDOWN -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_cooldown"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_cooldown_description"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/warningBackground"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/warning"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/txtCooldownValue"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/settings_default_seconds"
                            android:textColor="@color/warning"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderCooldown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="30"
                    android:valueTo="600"
                    android:stepSize="10"
                    android:value="120"
                    app:haloColor="@color/warningBackground"
                    app:thumbColor="@color/warning"
                    app:trackColorActive="@color/warning"
                    app:trackColorInactive="@color/divider"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider"/>


                <!-- RESTART DELTA -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_restart_delta"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_restart_delta_description"
                            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/primaryLight"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/txtRestartDeltaValue"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/settings_default_percentage"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderRestartDelta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="1"
                    android:valueTo="30"
                    android:stepSize="1"
                    android:value="10"
                    app:haloColor="@color/accentLight"
                    app:thumbColor="@color/primary"
                    app:trackColorActive="@color/primary"
                    app:trackColorInactive="@color/divider"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- SİSTEM AYARLARI -->

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartGarden.Card.Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="82dp"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_system_enabled"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtSystemEnabledDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_system_enabled_description"
                        android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSystemEnabled"
                    style="@style/Widget.SmartGarden.Switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/settings_system_enabled"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- İŞLEM BUTONLARI -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            style="@style/Widget.SmartGarden.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:text="@string/settings_save"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetSettings"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="@string/settings_reset_defaults"
            android:textAllCaps="false"
            android:textColor="@color/textSecondary"
            app:cornerRadius="18dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"/>

        <TextView
            android:id="@+id/txtSettingsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/settings_status_ready"
            android:textAppearance="@style/TextAppearance.SmartGarden.Body"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>