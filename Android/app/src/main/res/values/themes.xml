<?xml version="1.0" encoding="utf-8"?>

<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ========================================================= -->
    <!-- ANA UYGULAMA TEMASI                                       -->
    <!-- ========================================================= -->

    <style name="Base.Theme.SmartGarden"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- MARKA RENKLERİ -->

        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/textOnPrimary</item>

        <item name="colorPrimaryContainer">@color/primaryLight</item>
        <item name="colorOnPrimaryContainer">@color/primaryDark</item>

        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/textOnPrimary</item>

        <item name="colorSecondaryContainer">@color/accentLight</item>
        <item name="colorOnSecondaryContainer">@color/primaryDark</item>


        <!-- ARKA PLAN VE YÜZEYLER -->

        <item name="android:colorBackground">@color/background</item>

        <item name="colorOnBackground">@color/textPrimary</item>

        <item name="colorSurface">@color/card</item>
        <item name="colorOnSurface">@color/textPrimary</item>

        <item name="colorSurfaceVariant">@color/surfaceSoft</item>
        <item name="colorOnSurfaceVariant">@color/textSecondary</item>

        <item name="colorOutline">@color/border</item>
        <item name="colorOutlineVariant">@color/divider</item>


        <!-- DURUM ÇUBUKLARI -->

        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>


        <!-- PENCERE DAVRANIŞI -->

        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>

        <item name="android:fontFamily">sans</item>
        <item name="fontFamily">sans</item>


        <!-- VARSAYILAN BİLEŞEN STİLLERİ -->

        <item name="materialCardViewStyle">
            @style/Widget.SmartGarden.Card.Main
        </item>

        <item name="materialButtonStyle">
            @style/Widget.SmartGarden.Button.Primary
        </item>

        <item name="switchStyle">
            @style/Widget.SmartGarden.Switch
        </item>

    </style>


    <!-- UYGULAMANIN KULLANDIĞI TEMA -->

    <style name="Theme.SmartGarden"
        parent="Base.Theme.SmartGarden" />


    <!-- ========================================================= -->
    <!-- KART STİLLERİ                                             -->
    <!-- ========================================================= -->

    <style name="Widget.SmartGarden.Card.Main"
        parent="Widget.Material3.CardView.Elevated">

        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">2dp</item>

        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>

        <item name="android:clipToOutline">true</item>

    </style>


    <style name="Widget.SmartGarden.Card.Featured"
        parent="Widget.Material3.CardView.Elevated">

        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">2dp</item>

        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>

        <item name="android:clipToOutline">true</item>

    </style>


    <style name="Widget.SmartGarden.Card.Inner"
        parent="Widget.Material3.CardView.Filled">

        <item name="cardBackgroundColor">@color/surfaceSoft</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>

        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>

        <item name="android:clipToOutline">true</item>

    </style>


    <style name="Widget.SmartGarden.Card.Success"
        parent="Widget.Material3.CardView.Filled">

        <item name="cardBackgroundColor">@color/onlineBackground</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>

        <item name="strokeColor">@color/online</item>
        <item name="strokeWidth">1dp</item>

    </style>


    <style name="Widget.SmartGarden.Card.Error"
        parent="Widget.Material3.CardView.Filled">

        <item name="cardBackgroundColor">@color/offlineBackground</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>

        <item name="strokeColor">@color/offline</item>
        <item name="strokeWidth">1dp</item>

    </style>


    <!-- ========================================================= -->
    <!-- BUTON STİLLERİ                                            -->
    <!-- ========================================================= -->

    <style name="Widget.SmartGarden.Button.Primary"
        parent="Widget.Material3.Button">

        <item name="android:layout_height">58dp</item>

        <item name="backgroundTint">@color/buttonStart</item>
        <item name="android:textColor">@color/textOnPrimary</item>

        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>

        <item name="cornerRadius">18dp</item>

        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>

        <item name="android:minHeight">0dp</item>
        <item name="elevation">0dp</item>

        <item name="rippleColor">#40FFFFFF</item>

    </style>


    <style name="Widget.SmartGarden.Button.Stop"
        parent="Widget.SmartGarden.Button.Primary">

        <item name="backgroundTint">@color/buttonStop</item>

    </style>


    <style name="Widget.SmartGarden.Button.Disabled"
        parent="Widget.SmartGarden.Button.Primary">

        <item name="backgroundTint">@color/buttonDisabled</item>

    </style>


    <!-- ========================================================= -->
    <!-- SWITCH STİLİ                                              -->
    <!-- ========================================================= -->

    <style name="Widget.SmartGarden.Switch"
        parent="Widget.Material3.CompoundButton.MaterialSwitch">

        <item name="thumbTint">@color/switch_thumb_selector</item>
        <item name="trackTint">@color/switch_track_selector</item>

        <item name="android:minWidth">52dp</item>
        <item name="android:minHeight">32dp</item>

    </style>


    <!-- ========================================================= -->
    <!-- METİN STİLLERİ                                            -->
    <!-- ========================================================= -->

    <style name="TextAppearance.SmartGarden.ScreenTitle"
        parent="TextAppearance.Material3.HeadlineSmall">

        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>

    </style>


    <style name="TextAppearance.SmartGarden.CardTitle"
        parent="TextAppearance.Material3.TitleMedium">

        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>

    </style>


    <style name="TextAppearance.SmartGarden.Body"
        parent="TextAppearance.Material3.BodyMedium">

        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">12sp</item>

    </style>


    <style name="TextAppearance.SmartGarden.Label"
        parent="TextAppearance.Material3.LabelMedium">

        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>

    </style>


    <style name="TextAppearance.SmartGarden.Value"
        parent="TextAppearance.Material3.TitleLarge">

        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>

    </style>


    <style name="TextAppearance.SmartGarden.MoistureValue"
        parent="TextAppearance.Material3.DisplaySmall">

        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">52sp</item>
        <item name="android:textStyle">bold</item>

    </style>

</resources>